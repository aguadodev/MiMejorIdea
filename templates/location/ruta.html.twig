{% extends 'base.html.twig' %}

{% block title %}Ruta{% endblock %}

{% block body %}
    <h2>Ruta</h2>

    <div id="map" style="height: 500px;"></div>


    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <a href="{{ app.request.headers.get('referer') ?? path('app_index') }}" class="btn btn-primary">Volver</a>


<script>
    const home = [{{ homeLocation.latitude }}, {{ homeLocation.longitude }}];
    const work = [{{ workLocation.latitude }}, {{ workLocation.longitude }}];

    const map = L.map('map').setView(home, 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19
    }).addTo(map);

    L.marker(home).addTo(map).bindPopup("Casa");
    L.marker(work).addTo(map).bindPopup("Traballo");

    
    // Debuxa a liña entre os puntos
    //L.polyline([home, work]).addTo(map);
    // Debuxa a ruta entre os puntos
    showRoute(home, work);
    


    // Ajustar la vista para mostrar todas las rutas
    const bounds = L.latLngBounds([home, work]);

    map.fitBounds(bounds, { padding: [100, 100] });


    async function showRoute(start, end) {
        // Colores para las rutas
        const routeColors = [
            "#3498db", "#e67e22", "#9b59b6", "#f1c40f", "#1abc9c",
            "#e74c3c", "#34495e", "#16a085", "#8e44ad", "#d35400",
            "#2980b9", "#c0392b", "#27ae60", "#f39c12", "#2c3e50"
        ];        
        const routeData = await getRoute(start, end, routeColors[0]);
        routeData.layer.addTo(map);
    }


    // Función para obtener una ruta desde el servicio de routing OSRM
    async function getRoute(start, end, color) {
        try {
            const response = await fetch(
                `https://router.project-osrm.org/route/v1/driving/${start[1]},${start[0]};${end[1]},${end[0]}?overview=full&geometries=geojson`
            );
            const data = await response.json();
            
            if (data.routes && data.routes.length > 0) {
                const route = data.routes[0];
                const routeGeometry = L.geoJSON(route.geometry, {
                    style: {
                        color: color,
                        weight: 4,
                        //opacity: 0.7
                    }
                });
                
                return {
                    layer: routeGeometry,
                    distance: (route.distance / 1000).toFixed(1) + ' km',
                    duration: Math.round(route.duration / 60) + ' min'
                };
            }
        } catch (error) {
            console.error("Error al obtener la ruta:", error);
            
            // En caso de error, dibujar una línea recta
            const straightLine = L.polyline([start, end], {
                color: color,
                weight: 3,
                opacity: 0.6,
                dashArray: '5, 10'
            });
            
            // Calcular distancia aproximada
            const distance = map.distance(start, end) / 1000;
            
            return {
                layer: straightLine,
                distance: distance.toFixed(1) + ' km',
                duration: 'N/A'
            };
        }
    }
</script>


{% endblock %}
