{% extends 'base.html.twig' %}

{% block title %}Crear Localización{% endblock %}

{% block body %}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<h2>Crear Localización</h2>
{{ form_start(form) }}

<div class="mb-3">
    {{ form_label(form.address) }}
    {{ form_widget(form.address, { 'attr': { 'id': 'location_address' } }) }}
</div>

<div id="map" style="height: 480px;"></div>

{{ form_widget(form.latitude, { 'attr': {'id': 'latitude'} }) }}
{{ form_widget(form.longitude, { 'attr': {'id': 'longitude'} }) }}
{{ form_widget(form.street, { 'attr': {'id': 'street'} }) }}
{{ form_widget(form.city, { 'attr': {'id': 'city'} }) }}
{{ form_widget(form.state, { 'attr': {'id': 'state'} }) }}
{{ form_widget(form.postcode, { 'attr': {'id': 'postcode'} }) }}
{{ form_widget(form.country, { 'attr': {'id': 'country'} }) }}

<button class="btn btn-primary">Gardar</button>
<a href="javascript:history.back()" class="btn btn-secondary">Volver</a>
{{ form_end(form) }}


<script>
// @ Revisar Localización inicial. Usar Geolocalización en base a IP
let initialLocation = [42.3896237, -8.7126597]; // IES Chan do Monte de Marín

const map = L.map('map').setView(initialLocation, 13);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {maxZoom: 19,}).addTo(map);

let marker = L.marker(initialLocation, { draggable: true }).addTo(map);


init();


// Autocompletado SIN API KEY → Nominatim
let timeout = null;
document.getElementById('location_address').addEventListener('input', function() {
    clearTimeout(timeout);
    timeout = setTimeout(async () => {
        const q = this.value;
        if (q.length < 3) return;

        const url = `https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&q=${encodeURIComponent(q)}`;
        const res = await fetch(url);
        const results = await res.json();
        if (results.length === 0) return;

        const best = results[0];

        // mover mapa e marcador
        map.setView([best.lat, best.lon], 16);
        marker.setLatLng([best.lat, best.lon]);

        updateHiddenFields(best.lat, best.lon);
        updateAddressFields(best);
    }, 500);
});



async function init() {
    try {
        initialLocation = await obtenerCoordenadas();
    } catch (e) {
        console.warn("Non se puideron obter as coordenadas:", e);
        initialLocation = [42.3896237, -8.7126597];
    }
    // mover mapa e marcador
        map.setView(initialLocation, 16);
        marker.setLatLng(initialLocation);
        await actualizar(initialLocation[0], initialLocation[1]);
}

async function obtenerCoordenadas() {
    return new Promise((resolve, reject) => {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    const lat = pos.coords.latitude;
                    const lon = pos.coords.longitude;
                    resolve([lat, lon]);
                },
                (error) => {
                    reject("Error ao obter ubicación: " + error.message);
                }
            );
        } else {
            reject("Xeolocalización non soportada");
        }
    });
}

// Cando moves o marcador → actualizar dirección e campos
marker.on('dragend', async function(e) {
    const { lat, lng } = e.target.getLatLng();
    await actualizar(lat, lng)
});

// Actualizar marcador cuando se hace clic en el mapa
map.on('click', async function (e) {
    const { lat, lng } = e.latlng;
    marker.setLatLng(e.latlng);
    await actualizar(lat, lng)
});


async function actualizar(lat, lng) {
    updateHiddenFields(lat, lng);

    const data = await reverseGeocode(lat, lng);
    document.getElementById('location_address').value = data.display_name;
    updateAddressFields(data);
}

function updateHiddenFields(lat, lng) {
    document.getElementById('location_latitude').value = lat;
    document.getElementById('location_longitude').value = lng;
}

function updateAddressFields(details) {
    document.getElementById('location_street').value   = details.address.street ?? details.address.road ?? '';
    document.getElementById('location_city').value     = details.address.city ?? details.address.town ?? '';
    document.getElementById('location_state').value    = details.address.province ?? '';
    document.getElementById('location_postcode').value = details.address.postcode ?? '';
    document.getElementById('location_country').value  = details.address.country ?? '';
}

async function reverseGeocode(lat, lng) {
    const url = `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&addressdetails=1`;
    const res = await fetch(url);
    //alert (url);
    return await res.json();
}

</script>

{% endblock %}
