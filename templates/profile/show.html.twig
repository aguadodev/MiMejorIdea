{% extends 'base.html.twig' %}

{% block title %}Perfil de Usuari@{% endblock %}

{% block body %}
	<h2>Perfil de Usuari@</h2>

    {% if user.photoFilename %}
        <p><a href="{{ asset('assets/img/profile_photos/' ~ user.photoFilename) }}">
        <img height="200" src="{{ asset('assets/img/profile_photos/' ~ user.photoFilename) }}">
        </a></p>
    {% else %}
        <p><a href="{{ path('app_profile_edit') }}">
        <img width="200" src="{{ asset('assets/img/profile_photos/default_profile_photo.png') }}">
        </a></p>    
    {% endif %}

	<table class="table">
		<tbody>
			<tr>
				<th>Email</th>
				<td>{{ user.email }}</td>
			</tr>
			<tr>
				<th>Roles</th>
				<td>{{ user.roles ? user.roles|json_encode : '' }}</td>
			</tr>
			<tr>
				<th>Correo verificado?</th>
				<td>{{ user.isVerified ? 'Yes' : 'No' }}
					{% if not user.isVerified %}
						<a href="{{ path('app_resend_email') }}" class="button primary small">Verificar correo electrónico</a>
					{% endif %}

				</td>
			</tr>
			<tr>
				<th>Username</th>
				<td>{{ user.username }}</td>
			</tr>
			<tr>
				<th>CreatedAt</th>
				<td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>UpdatedAt</th>
				<td>{{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>LastLogin</th>
				<td>{{ user.lastLogin ? user.lastLogin|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>Enabled</th>
				<td>{{ user.enabled ? 'Yes' : 'No' }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('app_profile_edit') }}" class="btn btn-primary">Editar</a>

	{{ include('profile/_delete_form.html.twig') }}

	<a href="{{ path('app_dashboard') }}" class="btn btn-secondary">Volver al Dashboard</a>

{% endblock %}
