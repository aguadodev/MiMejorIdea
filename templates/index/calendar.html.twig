{% extends 'base.html.twig' %}

{% block title %}Mi Mejor Idea - Calendario{% endblock %}

{% block body %}

    <h2>Calendario</h2>

    <div id="calendar"></div>
    
    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        {% if app.user.perfilpersonal %}
        {% endif %}
    {% else %}
    {% endif %}

{% endblock %}


{% block javascripts %}
    {{ parent() }}
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.19/index.global.min.js'></script>

    <script>

    {# PROBAR PARA REDIMENSIONAR EL CALENDARIO CUANDO SE COMPRIME LA BARRA DE NAVEGACIÓN
    // Eliminar "var" en la declaración de "var calendar" tras DOMContentLoaded
    let calendar;
    document.querySelector('.toggle-sidebar')
        .addEventListener('click', function () {
            setTimeout(function () {
                calendar.updateSize();
            }, 300); // espera á animación CSS
        });    
    #}

      document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            themeSystem: 'bootstrap5',
            locale: 'es',       // Textos en español
            firstDay: 1,        // Lunes como primer día de la semana            
            initialView: 'dayGridMonth',
            // Opcional: eventos de exemplo
            events: [
                { title: 'Despliegue WebApp', start: '2025-12-03' },
            ],

            eventClick: function(info) {
            alert("Evento: " + info.event.title);
        }            
        });
        calendar.render();
      });

    </script>

{% endblock %}