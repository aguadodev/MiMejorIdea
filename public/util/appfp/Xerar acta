                }
            </style>
        </head>
        <body>
            <div class="documento">
                <div class="contenido">
                    <h1>ACTA DA XUNTA DA 1ª AVALIACIÓN</h1>
                    
                    <!-- Táboa de datos xerais -->
                    <table style="width: 100%; margin-bottom: 20px;">
                        <tr>
                            <td style="width: 33%; text-align: center;"><strong>CURSO</strong><br><span class="smallcaps">${curso}</span></td>
                            <td style="width: 33%; text-align: center;"><strong>GRUPO</strong><br><span class="smallcaps">${grupo}</span></td>
                            <td style="width: 34%; text-align: center;"><strong>DATA</strong><br>${dataFormateada}</td>
                        </tr>
                        <tr>
                            <td style="text-align: center;"><strong>TITOR/A:</strong></td>
                            <td colspan="2"><span class="smallcaps"><strong>${titor}</strong></span></td>
                        </tr>
                    </table>
                    
                    <!-- Sección 1: Valoración xeral (EDITABLE) -->
                    <div class="section-title">1. VALORACIÓN XERAL DO GRUPO</div>
                    <div class="editable" contenteditable="true" data-placeholder="Escribe aquí a valoración xeral do grupo...">
                        ${valoracionXeral || ''}
                    </div>
                    
                    <!-- Sección 2: Distribución de suspensos -->
                    <div class="section-title">2. NÚMERO DE ALUMNADO CON X MATERIAS SUSPENSAS</div>
                    <table>
                        <thead>
                            <tr><th>Situación académica</th><th>Nº</th><th>%</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>Alumnado con TODAS as materias APROBADAS</td><td class="text-center">${contadorSuspensos[0] || 0}</td><td class="text-center">${porcentaxes[0]}%</td></tr>
                            <tr><td>Alumnado con só 1 materia SUSPENSA</td><td class="text-center">${contadorSuspensos[1] || 0}</td><td class="text-center">${porcentaxes[1]}%</td></tr>
                            <tr><td>Alumnado con 2 materias SUSPENSAS</td><td class="text-center">${contadorSuspensos[2] || 0}</td><td class="text-center">${porcentaxes[2]}%</td></tr>
                            <tr><td>Alumnado con 3 materias SUSPENSAS</td><td class="text-center">${contadorSuspensos[3] || 0}</td><td class="text-center">${porcentaxes[3]}%</td></tr>
                            <tr><td>Alumnado con 4 materias SUSPENSAS</td><td class="text-center">${contadorSuspensos[4] || 0}</td><td class="text-center">${porcentaxes[4]}%</td></tr>
                            <tr><td>Alumnado con 5 OU MÁIS materias SUSPENSAS</td><td class="text-center">${contadorSuspensos['5+'] || 0}</td><td class="text-center">${porcentaxes['5+']}%</td></tr>
                            <tr><td>Alumnado con TODAS as materias SUSPENSAS</td><td class="text-center">${contadorSuspensos['todos'] || 0}</td><td class="text-center">${porcentaxes['todos']}%</td></tr>
                            <tr style="background:#f0f0f0;"><td class="bold">TOTAL ALUMNOS/AS DO GRUPO</td><td class="text-center bold">${totalAlumnos}</td><td class="text-center bold">100%</td></tr>
                        </tbody>
                    </table>
                    
                    <!-- Sección 3: Suspensos por módulo -->
                    <div class="section-title">3. NÚMERO DE ALUMNADO SUSPENSO POR MATERIA/MÓDULO</div>
                    <table>
                        <thead>
                            <tr><th>Materia / Módulo</th><th>Total</th><th>Suspensos</th><th>%</th></tr>
                        </thead>
                        <tbody>
                            ${filasModulos}
                        </tbody>
                    </table>
                    
                    <!-- Sección 4: Dificultades (EDITABLE) -->
                    <div class="section-title">4. MATERIAS/MÓDULOS NAS QUE SE CONCENTRAN AS MAIORES DIFICULTADES</div>
                    <div class="editable" contenteditable="true" data-placeholder="Escribe aquí as materias con maiores dificultades...">
                        ${dificultadesTexto}
                    </div>
                    
                    <!-- Sección 5: Acordos grupo (EDITABLE) -->
                    <div class="section-title">5. ACORDOS TOMADOS EN RELACIÓN AO GRUPO</div>
                    <div class="editable" contenteditable="true" data-placeholder="Escribe aquí os acordos tomados...">
                        ${acordosGrupo || ''}
                    </div>
                    
                    <!-- Sección 6 -->
                    <div class="section-title">6. ACORDOS TOMADOS RESPECTO DO ALUMNADO CON DIFICULTADES DE APRENDIZAXE</div>
                    <div class="editable" contenteditable="true" data-placeholder="Especificar alumnado e medidas (Ref, Apo, ACS, Opt, IL, Flex)...">
                        <strong>MEDIDAS:</strong> Reforzo (Ref); Apoio (Apo); ACS; Cambio de optativa (Opt); Inmersión lingüística (IL); Flexibilización (Flex)<br><br>
                    </div>
                    
                    <!-- Sección 7 -->
                    <div class="section-title">7. ACORDOS TOMADOS RESPECTO DO ALUMNADO CON PROBLEMAS DE COMPORTAMENTO E ASISTENCIA</div>
                    <div class="editable" contenteditable="true" data-placeholder="Especificar alumnado e medidas...">
                        <strong>MEDIDAS:</strong> Cambio de grupo; cambio de situación na aula; medidas de control; protocolo de absentismo; perda do dereito á avaliación continua; abandono materia<br><br>
                    </div>
                    
                    <!-- Sección 8 -->
                    <div class="section-title">8. SOLICITUDE DO EQUIPO DOCENTE PARA FALAR CO ALUMNADO</div>
                    <div class="editable" contenteditable="true" data-placeholder="Alumnado co que se require entrevista individual...">
                    </div>
                    
                    <!-- Sección 9 -->
                    <div class="section-title">9. SOLICITUDE DO EQUIPO DOCENTE PARA FALAR COAS FAMILIAS</div>
                    <div class="editable" contenteditable="true" data-placeholder="Familias coas que se require entrevista...">
                    </div>
                    
                    <!-- Sección 10: Observacións (EDITABLE) -->
                    <div class="section-title">10. OUTRAS OBSERVACIÓNS</div>
                    <div class="editable" contenteditable="true" data-placeholder="Engade aquí outras observacións...">
                        ${observacions || ''}
                    </div>
                    
                    <!-- Firma -->
                    <div class="signature">
                        <p>Marín, a ${dataFormateada}</p>
                        <div class="signature-line">
