async function xerarActaHTML() {
    try {
        // 1. Verificar datos
        if (!datosAnalise || !datosAnalise.estadisticasModulos) {
            alert('⚠️ Primeiro analiza un ficheiro CSV');
            return;
        }
        
        const exportarBtn = document.getElementById('exportarActaBtn');
        const textoOrixinal = exportarBtn.textContent;
        exportarBtn.textContent = '⏳ Xerando acta...';
        exportarBtn.disabled = true;
        
        // 2. Obter datos do formulario
        const dataRaw = document.getElementById('dataActa').value;
        const dataFormateada = dataRaw ? new Date(dataRaw).toLocaleDateString('gl-ES', {
            year: 'numeric', month: 'long', day: 'numeric'
        }) : new Date().toLocaleDateString('gl-ES', {
            year: 'numeric', month: 'long', day: 'numeric'
        });
        
        const titor = document.getElementById('titorActa').value.trim() || 'Óscar Núñez Aguado';
        const curso = document.getElementById('cursoActa').value.trim() || '2025-26';
        const grupo = document.getElementById('grupoActa').value.trim() || 'DAM1';
        const valoracionXeral = document.getElementById('valoracionXeral').value.trim() || '';
        const acordosGrupo = document.getElementById('acordosGrupo').value.trim() || '';
        const observacions = document.getElementById('observacions').value.trim() || '';
        
        const { estadisticasModulos, contadorSuspensos, totalAlumnos, modulosOrdenados, listaxesPorCategoria } = datosAnalise;
        
        // 3. Calcular porcentaxes
        const porcentaxes = {};
        for (const key in contadorSuspensos) {
            porcentaxes[key] = totalAlumnos > 0 ? ((contadorSuspensos[key] / totalAlumnos) * 100).toFixed(1) : '0';
        }
        
        // 4. Xerar filas da táboa de módulos
        let filasModulos = '';
        for (const modulo of modulosOrdenados) {
            const stats = estadisticasModulos[modulo];
            const porc = stats.avaliados > 0 ? (stats.suspensos / stats.avaliados * 100).toFixed(1) : '0';
            filasModulos += `
                <tr>
                    <td style="border: 1px solid #000; padding: 6px;">${modulo}</td>
                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">${stats.matriculados}</td>
                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">${stats.suspensos}</td>
                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">${porc}%</td>
                </tr>
            `;
        }
        
        // 5. Xerar listaxes de alumnos
        const xerarListaxe = (alumnos) => {
            if (!alumnos || alumnos.length === 0) return '—';
            return alumnos.map(nome => `• ${nome}`).join('<br>');
        };
        
        // 6. Identificar módulos con maiores dificultades
        const modulosDificultades = modulosOrdenados
            .map(modulo => {
                const stats = estadisticasModulos[modulo];
                const porc = stats.avaliados > 0 ? (stats.suspensos / stats.avaliados * 100).toFixed(1) : 0;
                return { materia: modulo, suspensos: stats.suspensos, porcentaxe: porc };
            })
            .sort((a, b) => b.suspensos - a.suspensos)
            .slice(0, 3);
        
        const dificultadesTexto = modulosDificultades.length > 0 
            ? modulosDificultades.map(m => `<strong>${m.materia}</strong> (${m.suspensos} suspensos, ${m.porcentaxe}%)`).join('<br>')
            : 'Non se detectaron dificultades significativas';
        
        // 7. Xerar o HTML completo con modo edición
        const htmlContent = `<!DOCTYPE html>
        <html lang="gl">
        <head>
            <meta charset="UTF-8">
            <title>Acta Xunta Avaliación - ${grupo}</title>
            <style>
                /* Estilos para pantalla (edición) */
