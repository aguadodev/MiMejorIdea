                    line-height: 1.4;
                    background: #e0e0e0;
                    padding: 30px 20px;
                }
                
                /* Contedor do documento */
                .documento {
                    max-width: 1200px;
                    margin: 0 auto;
                    background: white;
                    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
                }
                
                /* Contido interno con márxes exactas */
                .contenido {
                    padding: 1.27cm 2.5cm 0.8cm 2.5cm;
                }
                
                /* Estilos para impresión */
                @media print {
                    body {
                        background: white;
                        padding: 0;
                        margin: 0;
                    }
                    .documento {
                        box-shadow: none;
                        margin: 0;
                    }
                    .contenido {
                        padding: 0;
                        margin: 0;
                    }
                    @page {
                        size: A4;
                        margin: 1.27cm 2.5cm 0.8cm 2.5cm;
                    }
                    .no-print {
                        display: none;
                    }
                    .editable {
                        border: none;
                        background: transparent;
                    }
                }
                
                /* Estilos para edición */
                .no-print {
                    position: fixed;
                    bottom: 20px;
                    right: 20px;
                    z-index: 1000;
                    display: flex;
                    gap: 10px;
                }
                
                .btn-print {
                    background: #3498db;
                    color: white;
                    border: none;
                    padding: 10px 20px;
                    border-radius: 5px;
                    cursor: pointer;
                    font-size: 14px;
                    font-weight: bold;
                    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
                }
                
                .btn-save {
                    background: #27ae60;
                    color: white;
                    border: none;
                    padding: 10px 20px;
                    border-radius: 5px;
                    cursor: pointer;
                    font-size: 14px;
                    font-weight: bold;
                    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
                }
                
                .btn-print:hover, .btn-save:hover {
                    opacity: 0.9;
                    transform: translateY(-2px);
                }
                
                h1 {
                    text-align: center;
                    font-size: 18pt;
                    text-transform: uppercase;
                    margin: 20px 0 25px 0;
                    font-family: "Trebuchet MS", sans-serif;
                }
                
                table {
                    width: 100%;
                    border-collapse: collapse;
                    margin: 15px 0;
