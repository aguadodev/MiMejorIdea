                        <p>💾 Para gardar como ODT, abre este ficheiro con LibreOffice e selecciona "Gardar como" → "ODT"</p>
                    </div>
                </div>
            </div>
            
            <!-- Botóns flotantes -->
            <div class="no-print">
                <button class="btn-print" onclick="window.print()">🖨️ Imprimir</button>
                <button class="btn-save" onclick="gardarHTML()">💾 Gardar HTML</button>
            </div>
            
            <script>
                function gardarHTML() {
                    const htmlContent = document.documentElement.outerHTML;
                    const blob = new Blob([htmlContent], {type: 'text/html'});
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = 'Acta_Xunta_Avaliacion_${grupo}_${curso}_${dataFormateada.replace(/\\//g, '-')}.html';
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                    alert('✅ Ficheiro HTML gardado! Podes abrilo despois para seguir editando.');
                }
            </script>
        </body>
        </html>`;
        
        // 8. Abrir nunha nova ventá ou descargar
        const ventana = window.open('', '_blank');
        ventana.document.write(htmlContent);
        ventana.document.close();
        
        exportarBtn.textContent = textoOrixinal;
        exportarBtn.disabled = false;
        
        alert('✅ Acta xerada! Abriuse unha nova ventá co documento.\n\n' +
              '✏️ Podes editar calquera sección facendo clic nas áreas amarelas.\n' +
              '🖨️ Imprime directamente desde o navegador.\n' +
              '💾 Garda como HTML para editar despois, ou abre con LibreOffice e garda como ODT.');
        
    } catch (error) {
        console.error('Erro detallado:', error);
        const exportarBtn = document.getElementById('exportarActaBtn');
        exportarBtn.textContent = '📄 Xerar Acta';
