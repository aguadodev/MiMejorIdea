                }
                
                .section-title {
                    font-size: 13pt;
                    font-weight: bold;
                    margin: 20px 0 10px 0;
                    background-color: #f0f0f0;
                    padding: 5px 8px;
                    border-left: 4px solid #2c3e50;
                }
                
                .smallcaps {
                    font-variant: small-caps;
                }
                
                .signature {
                    margin-top: 50px;
                    text-align: right;
                }
                
                .signature-line {
                    margin-top: 40px;
                    width: 280px;
                    text-align: center;
                    border-top: 1px solid black;
                    margin-left: auto;
                    padding-top: 8px;
                }
                
                /* Campos editables */
                .editable {
                    background-color: #fff9e6;
                    padding: 12px;
                    margin: 10px 0;
                    border: 1px dashed #e67e22;
                    border-radius: 4px;
                    min-height: 80px;
                }
                
                .editable:focus {
                    outline: none;
                    border-color: #3498db;
                    background-color: #fff;
                }
                
                .editable[contenteditable="true"]:empty:before {
                    content: attr(data-placeholder);
                    color: #999;
                    font-style: italic;
                }
                
                .text-center {
                    text-align: center;
                }
                
                .bold {
                    font-weight: bold;
                }
                
                .listaxe {
                    max-height: 200px;
                    overflow-y: auto;
                    text-align: left;
                }
                
                hr {
                    margin: 20px 0;
                }
                
                .info-footer {
